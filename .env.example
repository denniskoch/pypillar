# Copy to .env and fill in your values.
# Create the app registration in Entra ID (Azure AD):
#   API permissions: User.Read.All (application), Presence.Read.All (application)
#   Admin consent:   Required — click "Grant admin consent" after adding permissions
#   Client secret:   Certificates & secrets → New client secret → copy value immediately
#   USER_ID:         Entra ID → Users → your profile → Object ID

PYPILLAR_CLIENT_ID=00000000-0000-0000-0000-000000000000
PYPILLAR_TENANT_ID=00000000-0000-0000-0000-000000000000
PYPILLAR_CLIENT_SECRET=your-client-secret-value
PYPILLAR_USER_ID=00000000-0000-0000-0000-000000000000
PYPILLAR_COMPANY_NAME=ACME CORPORATION